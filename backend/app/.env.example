# WATCHDOG Environment Configuration
# Copy this to .env and configure

# ===========================================
# LLM PROXY CONFIGURATION
# ===========================================

# Mock mode (true = use hardcoded responses, false = call real LLM)
MOCK_LLM=true

# OpenRouter Configuration (when MOCK_LLM=false)
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use (see https://openrouter.ai/models for options)
# Free options: meta-llama/llama-3.1-8b-instruct:free
# Paid options: openai/gpt-4, anthropic/claude-3-opus, etc.
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# LLM Request Settings
LLM_TIMEOUT=30              # Request timeout in seconds
LLM_MAX_RETRIES=2          # Number of retry attempts on failure
FALLBACK_TO_MOCK=true      # Auto-fallback to mock responses on error

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Server host and port
HOST=0.0.0.0
PORT=8000

# Auto-reload on code changes (dev only)
RELOAD=true

# ===========================================
# CORS CONFIGURATION
# ===========================================

# Allowed origins (comma-separated)
# Use "*" for development, specific domains in production
CORS_ORIGINS=*

# ===========================================
# RISK ENGINE (Future Integration)
# ===========================================

# Risk engine endpoint (when real service is available)
# RISK_ENGINE_URL=http://localhost:8001/analyze
# RISK_ENGINE_API_KEY=your_risk_engine_key
