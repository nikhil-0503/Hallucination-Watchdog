# WATCHDOG Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM Provider Configuration
# ============================================

# Mock LLM: Use mock responses for testing (true/false)
MOCK_LLM=true

# OpenRouter API Key (if MOCK_LLM=false)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ============================================
# Google Generative AI (Gemini) - For Bias Detection
# ============================================

# Google Generative AI API Key for Gemini (required for bias analysis)
# Get your key from: https://ai.google.dev/
GOOGLE_GENERATIVEAI_API_KEY=your_google_generativeai_api_key_here

# ============================================
# FastAPI Server Configuration
# ============================================

HOST=0.0.0.0
PORT=8000
RELOAD=true

# ============================================
# CORS Configuration
# ============================================

# Allowed origins for CORS (comma-separated)
# In production, restrict to specific domains
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ============================================
# Database Configuration (if using)
# ============================================

DATABASE_URL=sqlite:///./watchdog.db

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=INFO
LOG_FILE=watchdog.log
