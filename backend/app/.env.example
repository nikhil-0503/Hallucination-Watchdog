# WATCHDOG Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM Provider Configuration
# ============================================

# Mock LLM: Use mock responses for testing (true/false)
MOCK_LLM=true

# OpenRouter API Key (if MOCK_LLM=false)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Preferred provider: gemini | groq | openrouter | auto
LLM_PROVIDER=gemini

# Provider failover order (used when LLM_AUTO_FAILOVER=true or LLM_PROVIDER=auto)
LLM_PROVIDER_ORDER=gemini,groq,openrouter

# If true, automatically try next provider when the primary one fails
LLM_AUTO_FAILOVER=true

# Optional: fallback to deterministic mock responses if all providers fail
FALLBACK_TO_MOCK=false

# OpenRouter model (if provider chain reaches OpenRouter)
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Groq API config
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini API config
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ============================================
# Google Generative AI (Gemini) - For Bias Detection
# ============================================

# Google Generative AI API Key for Gemini (required for bias analysis)
# Get your key from: https://ai.google.dev/
GOOGLE_GENERATIVEAI_API_KEY=your_google_generativeai_api_key_here

# ============================================
# FastAPI Server Configuration
# ============================================

HOST=0.0.0.0
PORT=8000
RELOAD=true

# ============================================
# CORS Configuration
# ============================================

# Allowed origins for CORS (comma-separated)
# In production, restrict to specific domains
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ============================================
# Database Configuration (if using)
# ============================================

DATABASE_URL=sqlite:///./watchdog.db

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=INFO
LOG_FILE=watchdog.log
