# Frontend Environment Configuration
# Copy this file to .env.local and update values as needed

# Backend API origin (no trailing /api) - Must be set before build on Railway
# Example: https://your-backend.railway.app
REACT_APP_API_URL=http://localhost:8000

# Optional runtime proxy target for frontend/server.js
# If set, frontend can proxy /api/* requests at runtime without rebuilds.
# BACKEND_URL=https://your-backend.railway.app

# Note: On Railway, set this in the dashboard under Variables
# REACT_APP_API_URL=https://your-backend.railway.app
